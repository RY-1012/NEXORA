# Backend Environment Template
# Copy this to .env.local and fill in your values

# ===== Database =====
DATABASE_URL=postgres://postgres:password@localhost:5432/nexora

# ===== Redis (Optional) =====
REDIS_URL=redis://localhost:6379

# ===== JWT =====
JWT_SECRET=local-dev-secret-change-before-production
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# ===== MinIO Storage (Optional) =====
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=nexora-media
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ===== SMTP / Email (Optional, use MailHog locally) =====
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@nexora.dev

# ===== Application =====
NODE_ENV=development
PORT=3000
